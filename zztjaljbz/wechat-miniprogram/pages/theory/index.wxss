.theory-page {
  padding-bottom: 40rpx;
}

.hero {
  margin-bottom: 24rpx;
}

.eyebrow,
.title,
.field-title,
.body-text,
.channel-title {
  display: block;
}

.eyebrow {
  color: #a45b38;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.title {
  color: #174d4b;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1.25;
  margin-bottom: 18rpx;
}

.channel-card {
  margin-bottom: 24rpx;
}

.channel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.channel-title {
  color: #25231f;
  font-size: 34rpx;
  font-weight: 850;
}

.field-title {
  color: #174d4b;
  font-size: 27rpx;
  font-weight: 800;
  margin-top: 18rpx;
  margin-bottom: 6rpx;
}

.body-text {
  color: #4a443d;
  font-size: 27rpx;
  line-height: 1.7;
}

.notice {
  border-color: #e2a68b;
  background: #fff7f1;
}
