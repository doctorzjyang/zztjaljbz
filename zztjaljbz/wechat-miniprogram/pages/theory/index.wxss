.theory-page {
  padding-bottom: 40rpx;
}

.hero {
  margin-bottom: 24rpx;
}

.eyebrow,
.title,
.section-title,
.field-title,
.body-text,
.channel-title,
.model-name,
.model-body,
.model-meaning,
.question-title,
.tip-text {
  display: block;
}

.eyebrow {
  color: #a45b38;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.title {
  color: #174d4b;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1.25;
  margin-bottom: 18rpx;
}

.channel-card {
  margin-bottom: 24rpx;
}

.model-card {
  margin-bottom: 24rpx;
}

.section-title {
  color: #174d4b;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.35;
  margin-bottom: 16rpx;
}

.model-row {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #e8dfd0;
  border-radius: 14rpx;
  background: #fffaf1;
}

.model-name {
  color: #a45b38;
  font-size: 28rpx;
  font-weight: 850;
  margin-bottom: 6rpx;
}

.model-body {
  color: #25231f;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.55;
}

.model-meaning {
  color: #5f594f;
  font-size: 26rpx;
  line-height: 1.65;
  margin-top: 6rpx;
}

.question-block,
.example-block {
  margin-top: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #eee5d7;
}

.question-block:last-child,
.example-block:last-child {
  border-bottom: 0;
}

.question-title {
  color: #25231f;
  font-size: 29rpx;
  font-weight: 850;
  line-height: 1.45;
  margin-bottom: 8rpx;
}

.tip-text {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #eef5f2;
  color: #174d4b;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.65;
}

.channel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.channel-title {
  color: #25231f;
  font-size: 34rpx;
  font-weight: 850;
}

.field-title {
  color: #174d4b;
  font-size: 27rpx;
  font-weight: 800;
  margin-top: 18rpx;
  margin-bottom: 6rpx;
}

.body-text {
  color: #4a443d;
  font-size: 27rpx;
  line-height: 1.7;
}

.notice {
  border-color: #e2a68b;
  background: #fff7f1;
}
