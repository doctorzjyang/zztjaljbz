.six-page {
  padding-bottom: 40rpx;
}

.top {
  margin-bottom: 24rpx;
}

.eyebrow {
  display: block;
  color: #a45b38;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.title {
  display: block;
  color: #174d4b;
  font-size: 44rpx;
  font-weight: 850;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.section-title {
  display: block;
  color: #174d4b;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.risk-card,
.question-card,
.result-wrap {
  margin-bottom: 24rpx;
}

.risk-line,
.option {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee5d7;
  color: #2c2925;
  font-size: 29rpx;
  line-height: 1.55;
}

.option checkbox {
  margin-right: 16rpx;
}

.option-content,
.option-label,
.option-note {
  display: block;
}

.option-content {
  flex: 1;
}

.option-label {
  color: #2c2925;
  font-size: 29rpx;
  line-height: 1.5;
}

.option-note {
  margin-top: 6rpx;
  color: #756f66;
  font-size: 24rpx;
  line-height: 1.55;
}

.risk-line:last-of-type,
.option:last-child {
  border-bottom: 0;
}

.risk-index {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #eef5f2;
  color: #2d6f68;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.warning-box,
.doctor-tip {
  display: block;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #fff1e8;
  color: #9a4320;
  font-size: 26rpx;
  line-height: 1.6;
}

.progress-row,
.score-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress,
.score-track {
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eadfce;
}

.progress-bar,
.score-bar {
  height: 100%;
  border-radius: inherit;
  background: #2d6f68;
}

.question-title {
  color: #25231f;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.4;
}

.actions {
  display: flex;
  justify-content: space-between;
  margin-top: 22rpx;
}

.actions .button {
  width: 48%;
}

.actions.single {
  margin-top: 20rpx;
}

.result-wrap {
  margin-top: 24rpx;
}

.result-warning {
  border-color: #e2a68b;
  background: #fff7f1;
}

.result-main {
  display: block;
  color: #25231f;
  font-size: 38rpx;
  font-weight: 850;
  line-height: 1.35;
  margin-bottom: 12rpx;
}

.score-row {
  margin: 18rpx 0;
  font-size: 28rpx;
}

.evidence {
  padding: 14rpx 0;
  color: #3d3831;
  font-size: 27rpx;
  line-height: 1.65;
  border-bottom: 1rpx solid #eee5d7;
}

.medicine-card {
  margin-top: 20rpx;
  padding: 18rpx;
  border: 1rpx solid #e8dfd0;
  border-radius: 14rpx;
  background: #fffaf1;
}

.medicine-name {
  display: block;
  color: #174d4b;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.medicine-text {
  display: block;
  color: #4a443d;
  font-size: 26rpx;
  line-height: 1.6;
  margin-top: 6rpx;
}

.summary-text {
  display: block;
  white-space: pre-wrap;
  color: #3d3831;
  font-size: 27rpx;
  line-height: 1.7;
}
