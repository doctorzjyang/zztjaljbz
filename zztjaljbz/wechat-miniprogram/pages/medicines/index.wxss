.medicine-page {
  padding-bottom: 40rpx;
}

.hero {
  margin-bottom: 24rpx;
}

.eyebrow,
.title,
.medicine-name,
.field-title,
.body-text {
  display: block;
}

.eyebrow {
  color: #a45b38;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.title {
  color: #174d4b;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1.25;
  margin-bottom: 18rpx;
}

.medicine-card {
  margin-bottom: 24rpx;
}

.search-panel {
  position: sticky;
  top: 0;
  z-index: 10;
  margin: 0 -32rpx 24rpx;
  padding: 18rpx 32rpx;
  background: rgba(247, 243, 234, 0.96);
  border-bottom: 1rpx solid #eadfce;
}

.search-box {
  display: flex;
  align-items: center;
  min-height: 76rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8cdbc;
  border-radius: 12rpx;
  background: #fffdf8;
}

.search-input {
  flex: 1;
  min-height: 72rpx;
  color: #25231f;
  font-size: 28rpx;
}

.clear-button {
  width: 112rpx;
  min-height: 56rpx;
  margin: 0 0 0 12rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #eef5f2;
  color: #2d6f68;
  font-size: 24rpx;
  line-height: 56rpx;
}

.channel-filter {
  display: flex;
  flex-wrap: wrap;
  margin: 12rpx -6rpx 0;
}

.channel-chip {
  margin: 6rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid #d8cdbc;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #4a443d;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
}

.channel-chip.active {
  border-color: #2d6f68;
  background: #2d6f68;
  color: #fff;
}

.filter-clear {
  width: 140rpx;
  min-height: 52rpx;
  margin: 6rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #fff1e8;
  color: #a45b38;
  font-size: 24rpx;
  line-height: 52rpx;
}

.result-count {
  display: block;
  margin-top: 10rpx;
  color: #756f66;
  font-size: 24rpx;
}

.medicine-name {
  color: #25231f;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.35;
  margin-bottom: 12rpx;
}

.pill-row {
  margin-bottom: 14rpx;
}

.ingredient-list {
  display: flex;
  flex-wrap: wrap;
  margin: -6rpx;
}

.ingredient-pill {
  margin: 6rpx;
  padding: 10rpx 16rpx;
  border: 1rpx solid #d8cdbc;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #4a443d;
  font-size: 25rpx;
  line-height: 1.35;
}

.ingredient-pill:active {
  background: #eef5f2;
  color: #174d4b;
}

.field-title {
  color: #174d4b;
  font-size: 27rpx;
  font-weight: 800;
  margin-top: 16rpx;
  margin-bottom: 6rpx;
}

.body-text {
  color: #4a443d;
  font-size: 27rpx;
  line-height: 1.65;
}

.empty-card {
  margin-bottom: 24rpx;
}
