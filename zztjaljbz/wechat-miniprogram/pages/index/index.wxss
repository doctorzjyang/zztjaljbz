.home {
  padding-bottom: 40rpx;
}

.hero {
  padding: 28rpx 4rpx 8rpx;
  margin-bottom: 28rpx;
}

.eyebrow {
  display: block;
  color: #a45b38;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.title {
  display: block;
  color: #174d4b;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 14rpx;
}

.lead {
  display: block;
  color: #5f594f;
  font-size: 30rpx;
  line-height: 1.65;
}

.tool-card,
.pending-card {
  margin-bottom: 28rpx;
}

.tool-title {
  display: block;
  margin: 16rpx 0 10rpx;
  color: #25231f;
  font-size: 36rpx;
  font-weight: 800;
}

.footer-note {
  display: block;
  color: #827a70;
  font-size: 24rpx;
  line-height: 1.7;
}
